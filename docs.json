{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Origami",
  "fonts": {
    "family": "Inter"
  },
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      { "label": "Home", "href": "https://betorigami.com" },
      { "label": "Support", "href": "mailto:support@betorigami.com" }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://forms.gle/Yqa9kyoxrCgp1FGs6"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Games",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index", "games/catalog"]
          },
          {
            "group": "Originals",
            "pages": [
              "games/plinko",
              "games/keno",
              "games/dice",
              "games/advanced-dice",
              "games/limbo",
              "games/mines",
              "games/diamonds",
              "games/wheel"
            ]
          },
          {
            "group": "Table Games",
            "pages": [
              "games/roulette",
              "games/baccarat",
              "games/blackjack"
            ]
          }
        ]
      },
      {
        "tab": "Operate",
        "groups": [
          {
            "group": "Start",
            "pages": [
              "operate/getting-started",
              "operate/integration-options"
            ]
          },
          {
            "group": "Configure",
            "pages": [
              "operate/edge-and-rtp",
              "operate/game-settings",
              "operate/currencies"
            ]
          },
          {
            "group": "Customize",
            "pages": ["operate/branding"]
          },
          {
            "group": "Trust",
            "pages": ["operate/provably-fair"]
          }
        ]
      },
      {
        "tab": "Product updates",
        "groups": [
          {
            "group": "Changelog",
            "pages": ["operate/changelog"]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": ["copy", "view"]
  },
  "feedback": {
    "suggestEdit": true
  },
  "footer": {
    "socials": {
      "x": "https://x.com/betorigami",
      "linkedin": "https://linkedin.com/company/betorigami"
    }
  }
}
